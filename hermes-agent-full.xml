<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <!--
    Hermes Agent - Full (Custom Build)
    https://github.com/NousResearch/hermes-agent
    Custom image: https://github.com/ebears/hermes-agent-unraid

    Template: https://github.com/ebears/hermes-agent-unraid

    Notes:
    - This uses a custom Docker image with additional dependencies pre-installed:
      playwright (browser automation), markdown (Matrix HTML rendering)
    - Build the custom image first — see Dockerfile.unraid in this repo
    - Run interactively: set Post Arguments to --gateway run
    - First run: the container will walk you through initial setup (API keys, chat platform config)
    - Restart after configuring /opt/data/.env to apply changes

    Setup:
    1. Build and push the custom image first — see README.unraid.md in this repo
    2. Update the Repository field below to point to your custom image
    3. Download this XML to /boot/config/docker.d/hermes-agent-full.xml on your Unraid server
    4. In the Docker UI, set Post Arguments: --gateway run
    5. Map /opt/data to a host path for persistence (e.g. /mnt/user/appdata/hermes-agent)
    6. Start the container and follow the logs for first-run setup instructions

    Docs: https://docs.hermesagent.ai/
  -->
  <Name>Hermes Agent (Full)</Name>
  <Description>
    Self-hosted AI agent gateway with messaging integrations.

    Supports: Discord, Telegram, WhatsApp, Signal, Matrix, Mattermost, SSH, and more.

    First run: the container will walk you through initial setup (API keys, chat platform config).
    Restart after configuring /opt/data/.env to apply changes.

    Note: This requires the custom Docker image to be built first.
    See README.unraid.md in https://github.com/ebears/hermes-agent-unraid for instructions.

    Image: docker.io/aralobster/hermes-agent:latest (build this first — see repo)
  </Description>
  <Repository>docker.io/aralobster/hermes-agent:latest</Repository>
  <BindTime>false</BindTime>
  <Networking>
    <Mode>bridge</Mode>
  </Networking>
  <Data />
  <Environment>
    <Variable Name="HERMES_HOME" Value="/opt/data" />
  </Environment>
  <Config />
  <Labels />
  <PostArguments>--gateway run</PostArguments>
  <Privileged>false</Privileged>
  <Icon>https://raw.githubusercontent.com/ebears/hermes-agent-unraid/main/hermes-icon.png</Icon>
</Container>
