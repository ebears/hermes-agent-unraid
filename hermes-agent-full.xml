<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <!--
    Hermes Agent - Full (Custom Build)
    https://github.com/NousResearch/hermes-agent
    Custom image: https://github.com/Aralobster/hermes-agent/pkgs/container/hermes-agent

    Template: https://github.com/ebears/hermes-agent-unraid

    Notes:
    - This uses a custom Docker image with additional dependencies pre-installed:
      playwright (browser automation), markdown (Matrix HTML rendering), uv (MCP tools)
    - Image is auto-built from fix/docker-matrix-update branch via GitHub Actions
    - Run interactively: set Post Arguments to --gateway run
    - First run: the container will walk you through initial setup (API keys, chat platform config)
    - Restart after configuring /opt/data/.env to apply changes

    Setup:
    1. Download this XML to /boot/config/docker.d/hermes-agent-full.xml on your Unraid server
    2. In the Docker UI, set Post Arguments: --gateway run
    3. Map /opt/data to a host path for persistence (e.g. /mnt/user/appdata/hermes-agent)
    4. Start the container and follow the logs for first-run setup instructions

    Updating: When a new image is pushed to GHCR, set the container to pull the latest image
    in the Docker UI.

    Docs: https://docs.hermesagent.ai/
  -->
  <Name>Hermes Agent (Full)</Name>
  <Description>
    Self-hosted AI agent gateway with messaging integrations.

    Supports: Discord, Telegram, WhatsApp, Signal, Matrix, Mattermost, SSH, and more.

    First run: the container will walk you through initial setup (API keys, chat platform config).
    Restart after configuring /opt/data/.env to apply changes.

    Note: This uses a custom Docker image with playwright and markdown pre-installed.
    The image is auto-built from the fix/docker-matrix-update branch when upstream updates.

    Image: ghcr.io/Aralobster/hermes-agent:fix/docker-matrix-update
  </Description>
  <Repository>ghcr.io/Aralobster/hermes-agent:fix-docker-matrix-update</Repository>
  <BindTime>false</BindTime>
  <Networking>
    <Mode>bridge</Mode>
  </Networking>
  <Data />
  <Environment>
    <Variable Name="HERMES_HOME" Value="/opt/data" />
  </Environment>
  <Config />
  <Labels />
  <PostArguments>--gateway run</PostArguments>
  <Privileged>false</Privileged>
  <Icon>https://raw.githubusercontent.com/ebears/hermes-agent-unraid/main/hermes-icon.png</Icon>
</Container>
