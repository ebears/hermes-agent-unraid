<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <!--
    Hermes Agent - Official Docker Image
    https://github.com/NousResearch/hermes-agent

    Template: https://github.com/ebears/hermes-agent-unraid

    Notes:
    - This uses the official nousresearch/hermes-agent:latest image
    - Run interactively: set Post Arguments to --gateway run
    - First run: the container will walk you through initial setup (API keys, chat platform config)
    - Restart after configuring /opt/data/.env to apply changes

    Setup:
    1. Download this XML to /boot/config/docker.d/hermes-agent-official.xml on your Unraid server
    2. In the Docker UI, set Post Arguments: --gateway run
    3. Map /opt/data to a host path for persistence (e.g. /mnt/user/appdata/hermes-agent)
    4. Start the container and follow the logs for first-run setup instructions

    Docs: https://docs.hermesagent.ai/
  -->
  <Name>Hermes Agent (Official)</Name>
  <Description>
    Self-hosted AI agent gateway with messaging integrations.

    Supports: Discord, Telegram, WhatsApp, Signal, Matrix, Mattermost, SSH, and more.

    First run: the container will walk you through initial setup (API keys, chat platform config).
    Restart after configuring /opt/data/.env to apply changes.

    Note: This uses the official nousresearch/hermes-agent:latest image. For a version with
    additional dependencies pre-installed, use "Hermes Agent (Full)" instead.

    Image: nousresearch/hermes-agent:latest
  </Description>
  <Repository>docker.io/nousresearch/hermes-agent:latest</Repository>
  <BindTime>false</BindTime>
  <Networking>
    <Mode>bridge</Mode>
  </Networking>
  <Data />
  <Environment>
    <Variable Name="HERMES_HOME" Value="/opt/data" />
  </Environment>
  <Config />
  <Labels />
  <PostArguments>--gateway run</PostArguments>
  <Privileged>false</Privileged>
  <Icon>https://raw.githubusercontent.com/ebears/hermes-agent-unraid/main/hermes-icon.png</Icon>
</Container>
